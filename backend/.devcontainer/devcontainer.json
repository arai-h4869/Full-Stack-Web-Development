{
	"name": "Full-Stack-Web-Development Backend",
	
	"build": {
		"dockerfile": "Dockerfile"
	},
	"forwardPorts": [8000],

	"postCreateCommand": "uv sync",

	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.vscode-pylance"
			],
			"settings": {
				"pylint.args": [
					"--load-plugins",
					"pylint_django",
					"--django-settings-module",
					"config.settings.development"
				]
			}
		}
	}
}
